{
  "name": "bitbabble-sdk",
  "version": "1.0.1",
  "description": "Official JavaScript/TypeScript SDK for the BitBabble sentiment analysis API",
  "author": "BitBabble",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "bitbabble",
    "sentiment",
    "sentiment-analysis",
    "nlp",
    "api",
    "sdk"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bitbabble/bitbabble-sdk.git",
    "directory": "packages/javascript"
  },
  "homepage": "https://bitbabble.net/docs"
}
